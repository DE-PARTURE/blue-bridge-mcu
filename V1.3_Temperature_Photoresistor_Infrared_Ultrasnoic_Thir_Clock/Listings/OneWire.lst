 134          
 135          /*******************************/
 136          void Temp_Get()
 137          {
 138   1        bit ack;
 139   1        u8 LSB , MSB;
 140   1        u8 index;
 141   1        u32 temp;
 142   1        ack = InitDS18B20();
 143   1        if(!ack)
 144   1        {
 145   2          Write_DS18B20(0xCC);              //跳过ROM设置
 146   2          Write_DS18B20(0xBE);              //读取暂存器指令
 147   2          LSB = Read_DS18B20();             //读取低八位
 148   2          MSB = Read_DS18B20();             //读取高八位
 149   2          temp = ( ((u32)MSB) << 8) + LSB;  //数据组合
 150   2          temp *= 625;                      //将DS18B20原始数据转化为温度数据
 151   2          //temp >>= 4;                     //清除小数位
 152   2          for(index = 0; index < 7; index ++)
 153   2          {//清空数码管缓冲区
 154   3            SMG_Buff[index] = 0xFF;
 155   3          }
 156   2          //分离数位
 157   2          SMG_Buff[1] = SMG[temp / 100000]; 
 158   2          SMG_Buff[2] = SMG[(temp / 10000) % 10] & 0x7F;
 159   2          SMG_Buff[3] = SMG[(temp / 1000) % 10];
 160   2          SMG_Buff[4] = SMG[(temp / 100) % 10];
 161   2          SMG_Buff[5] = SMG[(temp / 10) % 10];
 162   2          SMG_Buff[6] = SMG[temp % 10];
 163   2          SMG_Buff[7] = 0xC6;               //C
 164   2        }
 165   1        Start_DS18B20();
 166   1      }
