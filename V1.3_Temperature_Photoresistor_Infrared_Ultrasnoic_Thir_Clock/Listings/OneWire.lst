  14          //通过单总线向DS18B20写一个字节
  15          void Write_DS18B20(unsigned char dat)
  16          {
  17   1        unsigned char i;
  18   1        /*******************************/
  19   1        EA = 0;
  20   1        /*******************************/
  21   1        for(i=0;i<8;i++)
  22   1        {
  23   2          DQ = 0;
  24   2          DQ = dat&0x01;
  25   2          Delay_OneWire(5);
  26   2          DQ = 1;
  27   2          dat >>= 1;
  28   2        }
  29   1        Delay_OneWire(5);
  30   1        /*******************************/
  31   1        EA = 1;
  32   1        /*******************************/
  33   1      }
  34          
  35          //从DS18B20读取一个字节
  36          unsigned char Read_DS18B20(void)
  37          {
  38   1        unsigned char i;
  39   1        unsigned char dat;
  40   1        /*******************************/
  41   1        EA = 0;
  42   1        /*******************************/
  43   1        
  44   1        for(i=0;i<8;i++)
  45   1        {
  46   2          DQ = 0;
  47   2          dat >>= 1;
  48   2          DQ = 1;
  49   2          if(DQ)
  50   2          {
  51   3            dat |= 0x80;
  52   3          }     
  53   2          Delay_OneWire(5);
  54   2        }
