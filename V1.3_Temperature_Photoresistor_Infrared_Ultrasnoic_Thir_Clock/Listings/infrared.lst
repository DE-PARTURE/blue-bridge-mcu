  89   2          for(j = 0; j < 8; j ++)
  90   2          {
  91   3            //先判断每位的数据中的低电平是否超时
  92   3            time  = GetLowTime();
  93   3            if( (time < 313) || (time > 718) )
  94   3            {
  95   4              IE1 = 0;
  96   4              return;
  97   4            }
