 101   3            {
 102   4              byt >>= 1;
 103   4            }
 104   3            else if( (time > 1345) || (time < 1751) )//值为1
 105   3            {
 106   4              byt >>= 1;
 107   4              byt |= 0x80;
 108   4            }
 109   3            else//不符合上述两种条件即为误码
 110   3            {
