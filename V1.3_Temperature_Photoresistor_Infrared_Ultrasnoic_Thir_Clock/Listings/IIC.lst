  64          //通过I2C总线发送数据
  65          void IIC_SendByte(unsigned char byt)
  66          {
  67   1          unsigned char i;
  68   1      
  69   1          for(i=0; i<8; i++)
  70   1          {
  71   2              SCL  = 0;
  72   2              somenop
  73   2              if(byt & 0x80) SDA  = 1;
  74   2              else SDA  = 0;
  75   2              somenop
  76   2              SCL = 1;
  77   2              byt <<= 1;
  78   2              somenop
  79   2          }
  80   1          SCL  = 0;  
  81   1      }
  82          
  83          //从I2C总线上接收数据
  84          unsigned char IIC_RecByte(void)
  85          {
  86   1          unsigned char i, da;
  87   1          for(i=0; i<8; i++)
  88   1          {   
