  99          /**************************************************************************
 100          函数功能：电压获取
 101          入口参数：PCF8591控制器件地址
 102          返回值  ：无
 103          **************************************************************************/
 104          u8 AD_read(u8 add)
 105          {
 106   1        u8 dat;
 107   1        IIC_Start();
 108   1        IIC_SendByte(0x90); //发送写指令
 109   1        IIC_WaitAck();      //等待从机应答
 110   1        IIC_SendByte(add);  //写入控制器件地址
 111   1        IIC_WaitAck();      //等待从机应答
 112   1        IIC_Stop();
 113   1        
 114   1        IIC_Start();
C51 COMPILER V9.60.0.0   IIC                                                               10/08/2020 11:30:02 PAGE 3   

 115   1        IIC_SendByte(0x91); //发送读指令
 116   1        IIC_WaitAck();      //等待从机应答
 117   1        dat=IIC_RecByte();  //读取数据
 118   1        IIC_SendAck(0);     //发送非应答信号
 119   1        IIC_Stop();
 120   1        return dat;
 121   1      }
